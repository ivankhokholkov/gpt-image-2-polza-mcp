# ============================================================
# Polza Authentication
# ============================================================
# Вставь сюда свой ключ Polza
POLZA_AI_API_KEY="your-polza-api-key-here"
POLZA_BASE_URL=https://polza.ai/api

# ============================================================
# Model Settings
# ============================================================
# GPT Image 2 through Polza
GPT_IMAGE_MODEL=gpt-image-2

# ============================================================
# Polling Settings
# ============================================================
POLZA_POLL_INTERVAL_SECONDS=2
POLZA_POLL_TIMEOUT_SECONDS=120
POLZA_EXTERNAL_USER_ID=

# ============================================================
# Image Output Directory
# ============================================================
# This is the DEFAULT directory when output_path parameter is not specified.
# The output_path parameter in generate_image() always takes precedence.
#
# Precedence (highest to lowest):
# 1. output_path parameter in generate_image() call
# 2. IMAGE_OUTPUT_DIR environment variable (below)
# 3. ~/gpt-image-2-images (default fallback)
#
# Default: ~/gpt-image-2-images
# IMAGE_OUTPUT_DIR=/path/to/output

# ============================================================
# Image Response Settings
# ============================================================
# Return full-resolution images in MCP response instead of thumbnails
# WARNING: Full images can be large (3-7MB each for 4K)
# RETURN_FULL_IMAGE=false

# Optional: use this to group requests by user inside Polza
# POLZA_EXTERNAL_USER_ID=user-123
