{
  "mcpServers": {
    "gpt-image-2-polza-mcp-server": {
      "command": "uv",
      "args": [
        "run",
        "python",
        "-m",
        "gpt_image_2_polza_mcp_server.server"
      ],
      "cwd": ".",
      "env": {
        "POLZA_BASE_URL": "https://polza.ai/api",
        "LOG_LEVEL": "INFO",
        "LOG_FORMAT": "standard"
      }
    }
  },
  "server": {
    "name": "gpt-image-2-polza-mcp-server",
    "version": "0.6.0",
    "description": "GPT Image 2 generation and editing through the Polza media API",
    "entrypoint": "gpt_image_2_polza_mcp_server.server:create_app",
    "dependencies": [
      "fastmcp>=2.11.0",
      "pillow>=10.4.0",
      "python-dotenv>=1.0.1",
      "pydantic>=2.0.0"
    ],
    "dev_dependencies": [
      "ruff>=0.1.0",
      "pytest>=7.0.0",
      "pytest-asyncio>=0.21.0",
      "mypy>=1.0.0"
    ],
    "environment": {
      "POLZA_AI_API_KEY": {
        "required": true,
        "description": "Polza API key for media generation"
      },
      "POLZA_BASE_URL": {
        "required": false,
        "default": "https://polza.ai/api",
        "description": "Base URL for the Polza API"
      },
      "IMAGE_OUTPUT_DIR": {
        "required": false,
        "description": "Directory where generated images are saved"
      },
      "LOG_LEVEL": {
        "required": false,
        "default": "INFO",
        "description": "Logging level (DEBUG, INFO, WARNING, ERROR)"
      },
      "LOG_FORMAT": {
        "required": false,
        "default": "standard",
        "description": "Log format (standard, json, detailed)"
      },
      "FASTMCP_TRANSPORT": {
        "required": false,
        "default": "stdio",
        "description": "Transport protocol (stdio, http)"
      },
      "FASTMCP_HOST": {
        "required": false,
        "default": "127.0.0.1",
        "description": "Host for HTTP transport"
      },
      "FASTMCP_PORT": {
        "required": false,
        "default": "9000",
        "description": "Port for HTTP transport"
      },
      "POLZA_POLL_INTERVAL_SECONDS": {
        "required": false,
        "default": "2",
        "description": "Polling interval for media generation status"
      },
      "POLZA_POLL_TIMEOUT_SECONDS": {
        "required": false,
        "default": "120",
        "description": "Polling timeout for media generation status"
      }
    }
  }
}
